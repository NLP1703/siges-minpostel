# Configuration Base de Données
DB_HOST=localhost
DB_USER=root
DB_PASS=your_password
DB_NAME=siges_minpostel
DB_PORT=3306

# Configuration JWT
JWT_SECRET=your_very_long_secret_key_minimum_64_characters_for_security_purposes_here
JWT_EXPIRY=8h

# Configuration Serveur
PORT=5000
NODE_ENV=development

# CORS
FRONTEND_URL=http://localhost:3000

# Notifications Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@siges-minpostel.cm

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

# SMS - Orange Cameroun
ORANGE_SMS_URL=https://api.orange.cm/smsm/v1
ORANGE_SMS_SENDER=SIGES-MINPOSTEL
ORANGE_CLIENT_ID=your_orange_client_id
ORANGE_CLIENT_SECRET=your_orange_client_secret
ORANGE_ACCESS_TOKEN=your_orange_access_token

# SMS - MTN Cameroun
MTN_SMS_URL=https://api.mtn.cm/sms/v1
MTN_SMS_SENDER=SIGES-MINPOSTEL
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_TARGET_ENV=sandbox
