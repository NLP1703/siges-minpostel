# Configuration Base de Données
DB_HOST=localhost
DB_USER=root
DB_PASS=your_password
DB_NAME=siges_minpostel
DB_PORT=3306

# Configuration JWT
JWT_SECRET=your_very_long_secret_key_minimum_64_characters_for_security_purposes_here
